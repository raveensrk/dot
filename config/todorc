# Config for ,todo.sh — sourced as bash. Override any of these arrays.

# strings to grep (rg regex alternatives, joined with |)
patterns=(TODO IN_PROGRESS FIXME BUG LATER '\[ \]')

# file extensions to search
extensions=(md)

# dirs searched when run without argument
default_dirs=("$HOME/dot" "$HOME/iCloud/notes" "$HOME/work" "$HOME/repos")

# glob patterns to ignore (passed to rg as --glob '!<pattern>').
# Slash-free globs match basenames anywhere ('node_modules', '*.min.md');
# globs with a slash are matched at any depth ('archive/**' means '**/archive/**').
ignore=('node_modules', 'odysseus')
